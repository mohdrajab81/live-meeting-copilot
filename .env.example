# Azure Speech Service — required
SPEECH_KEY=your-azure-speech-key
SPEECH_REGION=eastus

# Azure Translator — optional (omit both if not using translation)
# If TRANSLATOR_KEY is set, TRANSLATOR_REGION is also required.
TRANSLATOR_KEY=your-azure-translator-key
TRANSLATOR_REGION=eastus
TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# Cost tracking — optional
# Set to your Azure Translator per-million-character rate in USD.
TRANSLATION_COST_PER_MILLION_USD=10.0

# Azure AI Foundry project + model — optional (needed for coach/topic/summary features)
PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Coach agent — optional
AGENT_ID=asst_xxx
# AGENT_NAME=my-profile-agent

# Topic agent — optional (falls back to AGENT_ID/AGENT_NAME if not set)
TOPIC_AGENT_ID=asst_xxx
# TOPIC_AGENT_NAME=my-topics-agent

# Summary agent — optional
SUMMARY_AGENT_ID=asst_xxx
# SUMMARY_AGENT_NAME=my-summary-agent
# SUMMARY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
