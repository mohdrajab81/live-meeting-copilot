# Azure AI Services key/region — required (shared by Speech + Translator)
AZURE_AI_SERVICES_KEY=your-azure-ai-services-key
AZURE_AI_SERVICES_REGION=eastus

# Nova-3 STT key — optional (preview). Create it in Deepgram Console > Project > Settings > API Keys.
NOVA3_API_KEY=

# Cost tracking — optional
# Set to your Azure Translator per-million-character rate in USD.
TRANSLATION_COST_PER_MILLION_USD=10.0

# Azure AI Foundry project — optional (needed for coach/summary features)
PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# Guidance declarative agent name — optional
GUIDANCE_AGENT_NAME=my-profile-agent

# Summary declarative agent name — optional
SUMMARY_AGENT_NAME=my-summary-agent

